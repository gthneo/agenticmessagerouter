# AMR / jl — configuration template. Copy values into your shell env or the
# secret files noted below. NEVER put real tokens or contact data in the repo.

# WeChat read MCP (powerdata) bearer token.
# Loaded from $WX_MCP_TOKEN, else from ~/.config/jl/wechat_mcp_token (git-ignored).
WX_MCP_TOKEN=

# fullwechat (structured WeChat backend) — REST endpoint + bearer token.
# Token also read from ~/.config/agent-wechat/token if env unset.
AGENT_WECHAT_URL=http://192.168.31.178:6174
AGENT_WECHAT_TOKEN=

# Audit-trail actor label written to the events table (who is acting).
JL_ACTOR=

# LLM provider selection for the 话术 assistant (LLM-optional — all blank = manual).
#   AMR_LLM_PROVIDER  pin a provider: "claude_code" (Claude Code Max plan, no API
#                     key — shells the `claude` CLI) or "claude" (Anthropic API).
#                     Unset → falls back to the API when ANTHROPIC_API_KEY is set.
#   AMR_CLAUDE_BIN    absolute path to the `claude` CLI (systemd has no login PATH).
AMR_LLM_PROVIDER=
AMR_CLAUDE_BIN=

# 1b method playbook (M1–M8 + 《影响力》/Cialdini) injected as draft background.
# The CONTENT lives OUTSIDE this public repo — point at a local file you maintain.
# Absent file → assistant degrades to the base style guide (no method block).
AMR_PLAYBOOK=~/.config/jl/playbook.md

# Real data lives OUTSIDE the repo:
#   ~/.config/jl/persons.json        editable seed (names/wxids/phones)
#   ~/.config/jl/jl.db               SQLite source of truth
#   ~/.config/jl/wechat_mcp_token    powerdata bearer (chmod 600)
#   ~/.config/agent-wechat/token     fullwechat bearer (chmod 600)
#   ~/.config/jl/playbook.md         method playbook (M1–M8 + Cialdini) — local only

# PowerData (MCP-over-HTTP WeChat read tool) — URL + token, LOCAL ONLY (never in repo).
#   POWERDATA_URL    else ~/.config/jl/powerdata_url
#   WX_MCP_TOKEN     else ~/.config/jl/wechat_mcp_token
POWERDATA_URL=
